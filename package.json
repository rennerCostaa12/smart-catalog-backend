{
  "name": "boilerplate-nodejs",
  "version": "1.0.0",
  "description": "Boilerplate Node.js com Express, TypeScript, Sequelize, MySQL, Yup e arquitetura em camadas.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --ignore-watch node_modules src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "migration:create": "sequelize-cli migration:generate --name",
    "migration:up": "sequelize-cli db:migrate",
    "migration:down": "sequelize-cli db:migrate:undo"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "sequelize",
    "mysql",
    "yup"
  ],
  "author": "Renner Costa",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1083.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "multer": "^2.2.0",
    "mysql2": "^3.11.3",
    "sequelize": "^6.37.3",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^22.7.4",
    "sequelize-cli": "^6.6.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
